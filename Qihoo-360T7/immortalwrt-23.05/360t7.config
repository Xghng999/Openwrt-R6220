#
CONFIG_MODULES=y
CONFIG_HAVE_DOT_CONFIG=y
CONFIG_HOST_OS_LINUX=y
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_DEVICE_mediatek_filogic_DEVICE_qihoo_360t7-ubootmod=y
# end of Target Devices
### 系统文件
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
### 定时重启autoreboot
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-i18n-autorebootk-zh-cn=y
### 实时流量监测
CONFIG_PACKAGE_luci-app-wrtbwmon=y
CONFIG_PACKAGE_luci-i18n-wrtbwmon-zh-cn=y
### 网速控制
CONFIG_PACKAGE_tc-tiny=y
CONFIG_PACKAGE_tc-bpf=y
CONFIG_PACKAGE_tc-full=y
CONFIG_PACKAGE_libxtables12=y
CONFIG_PACKAGE_tc-mod-iptables=y
# CONFIG_PACKAGE_luci-app-eqos=y
# CONFIG_PACKAGE_luci-i18n-eqos-zh-cn=y
### luci-app-nft-qos 网速控制最小Kb/S设置
CONFIG_PACKAGE_nft-qos=y
CONFIG_PACKAGE_kmod-nft-netdev=y
CONFIG_PACKAGE_kmod-nft-bridge=y
CONFIG_PACKAGE_nftables-nojson=y
CONFIG_PACKAGE_luci-app-nft-qos=y
CONFIG_PACKAGE_luci-i18n-nft-qos-zh-cn=y
### 应用过滤插件
# CONFIG_PACKAGE_appfilter=y
# CONFIG_PACKAGE_kmod-oaf=y
# CONFIG_PACKAGE_luci-compat=y
# CONFIG_PACKAGE_luci-app-oaf=y
# CONFIG_PACKAGE_luci-i18n-oaf-zh-cn=y
### 钉钉推送,企业微信推送,PushPlus推送
CONFIG_PACKAGE_luci-app-wechatpush=y
CONFIG_PACKAGE_luci-i18n-wechatpush-zh-cn=y
### zerotier内网穿透
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
#

